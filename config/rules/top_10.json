{
  "id": "top_10",
  "nome": "Top 10 Mitos/Micos",
  "descricao": "Ranking histórico das 10 maiores (MITOS) e 10 menores (MICOS) pontuações de toda a temporada. Premia destaques positivos e negativos.",
  "tipo": "ranking_historico",
  "status": "ativo",
  "versao": "1.0.0",

  "configuracao": {
    "modulo_ativo": true
  },

  "regras": {
    "calculo": {
      "metodo": "ranking_extremos_historicos",
      "fonte_dados": "collection:rodadas",
      "descricao": "Analisa TODAS as pontuações do campeonato e extrai os 10 maiores e 10 menores"
    },

    "mitos": {
      "descricao": "10 maiores pontuações históricas do campeonato",
      "quantidade": 10,
      "ordenacao": "DESC",
      "titulo_primeiro": "MELHOR MITO"
    },

    "micos": {
      "descricao": "10 menores pontuações históricas do campeonato",
      "quantidade": 10,
      "ordenacao": "ASC",
      "titulo_primeiro": "PIOR MICO"
    },

    "elegibilidade": {
      "participantes_inativos": "incluir_pontuacoes_anteriores",
      "rodada_nao_jogada": "excluir",
      "pontuacao_minima": null
    },

    "cache": {
      "collection": "top10caches",
      "ttl_minutos": 60,
      "calculo_historico": true
    }
  },

  "financeiro": {
    "impacto_banco": true,
    "tipo_transacao": ["MITO", "MICO"],
    "moeda": "BRL",
    "precisao_decimal": 2,
    "valores_defaults": {
      "mito_1": 30.00,
      "mico_1": -30.00,
      "decremento": 2.00,
      "descricao": "Valores reais por liga vêm do ModuleConfig (wizard). Defaults: 1o=30, 2o=28... dec=2"
    }
  },

  "ui": {
    "nomenclatura": {
      "mito_badge": "Xº MELHOR MITO",
      "mico_badge": "Xº PIOR MICO"
    },
    "icones": {
      "mito": "emoji_events",
      "mico": "sentiment_sad"
    },
    "cores": {
      "mito": "#ffd700",
      "mico": "#ef4444"
    }
  },

  "wizard": {
    "titulo": "Configurar Top 10 Mitos/Micos",
    "descricao": "Defina quantos participantes entram no ranking e os valores de premiacao",
    "perguntas": [
      {
        "id": "qtd_mitos",
        "tipo": "number",
        "label": "Quantas posicoes de MITOS?",
        "descricao": "Quantidade de melhores pontuacoes premiadas",
        "default": 10,
        "min": 3,
        "max": 20,
        "step": 1,
        "required": true,
        "afeta": "regras.mitos.quantidade"
      },
      {
        "id": "qtd_micos",
        "tipo": "number",
        "label": "Quantas posicoes de MICOS?",
        "descricao": "Quantidade de piores pontuacoes 'premiadas'",
        "default": 10,
        "min": 3,
        "max": 20,
        "step": 1,
        "required": true,
        "afeta": "regras.micos.quantidade"
      },
      {
        "id": "valor_mito_1",
        "tipo": "number",
        "label": "Valor do 1o MITO (R$)",
        "descricao": "Premio do melhor mito da temporada",
        "default": 30,
        "min": 0,
        "max": 500,
        "step": 1,
        "required": true,
        "afeta": "financeiro_override.valores_por_posicao.mitos.1"
      },
      {
        "id": "valor_mico_1",
        "tipo": "number",
        "label": "Valor do 1o MICO (R$)",
        "descricao": "Penalidade do pior mico (valor negativo)",
        "default": -30,
        "min": -500,
        "max": 0,
        "step": 1,
        "required": true,
        "afeta": "financeiro_override.valores_por_posicao.micos.1"
      },
      {
        "id": "decremento_valor",
        "tipo": "number",
        "label": "Decremento por posicao (R$)",
        "descricao": "Quanto diminui a cada posicao (ex: 1o=30, 2o=28, dec=2)",
        "default": 2,
        "min": 0,
        "max": 20,
        "step": 0.5,
        "required": true,
        "afeta": "regras_override.decremento_valor"
      }
    ]
  },

  "nota": "Habilitação por liga é controlada via ModuleConfig no MongoDB, não por este arquivo",

  "metadados": {
    "criado_em": "2025-12-14",
    "autor": "Sistema",
    "fonte": "controllers/top10CacheController.js, controllers/fluxoFinanceiroController.js"
  }
}
