  "conventions": {
    "naming": {
      "modules": "public/css/modules/{module-name}.css",
      "appFeatures": "public/participante/css/{feature-name}.css",
      "tokens": "public/css/_admin-tokens.css | public/participante/css/_app-tokens.css",
      "prefixo": "Nomes em kebab-case, sem prefixo generico (ex: nao usar 'styles-' ou 'custom-')"
    },
    "loadOrder": [
      "1. Tokens (_admin-tokens.css ou _app-tokens.css) - SEMPRE primeiro",
      "2. Base (style.css, base.css) ou Bundle (admin-shell.css)",
      "3. Fontes externas (Google Fonts CDN)",
      "4. Modules page-specific (modules/*.css)"
    ],
    "prohibited": [
      "Inline styles (style=) em HTML - usar classes CSS",
      "Cores hardcoded (#hex, rgb()) - usar var(--token)",
      "@keyframes locais se o tokens ja define (spin, pulse, fadeIn, slideUp, pulse-live)",
      "CSS em <style> tags dentro de HTML admin",
      "!important (exceto overrides de terceiros como Bootstrap)"
    ]
  }
}
