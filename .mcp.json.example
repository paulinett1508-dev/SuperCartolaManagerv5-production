{
  "mcpServers": {
    "mongo": {
      "command": "node",
      "args": ["mongo-server.js"],
      "env": {
        "MONGO_URI": "mongodb+srv://USER:PASS@cluster0.XXXXX.mongodb.net/cartola-manager?retryWrites=true&w=majority",
        "NODE_ENV": "production"
      }
    },
    "mongo-remote": {
      "type": "http",
      "url": "https://SEU_DOMINIO/mcp-mongo/mcp",
      "headers": {
        "x-mcp-token": "SEU_MCP_SECRET_TOKEN_AQUI"
      }
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "pplx-sua_chave_aqui"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {
        "NODE_ENV": "production"
      }
    }
  }
}
