# ===========================
# Super Cartola Manager - Environment Variables
# ===========================

# Node Environment (development | staging | production)
NODE_ENV=development

# Port
PORT=3000

# Base URL (obrigatorio em staging/production)
# BASE_URL=https://supercartolamanager.com.br

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/supercartolamanager

# Session Secret (gerar com: openssl rand -hex 32)
SESSION_SECRET=seu_secret_aqui

# ===========================
# Google OAuth (Admin Auth)
# ===========================
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu_client_id
GOOGLE_CLIENT_SECRET=seu_client_secret

# ===========================
# Admin Authorization
# ===========================
ADMIN_EMAILS=admin1@gmail.com,admin2@gmail.com
SUPER_ADMIN_EMAIL=admin1@gmail.com

# ===========================
# External APIs
# ===========================
API_FOOTBALL_KEY=sua_chave
SOCCERDATA_API_KEY=sua_chave
CARTOLA_GLB_TOKEN=seu_token

# ===========================
# Push Notifications (VAPID)
# ===========================
VAPID_PUBLIC_KEY=sua_chave_publica
VAPID_PRIVATE_KEY=sua_chave_privada

# ===========================
# GitHub (opcional - para deploy/scripts)
# ===========================
GITHUB_TOKEN=ghp_seu_token_aqui
GITHUB_OWNER=seu_usuario
GITHUB_REPO=SuperCartolaManagerv6

# ===========================
# Dev Admin Bypass (apenas development)
# ===========================
# DEV_ADMIN_BYPASS=true
