# ===========================
# Super Cartola Manager - Environment Variables
# ===========================
# Copie este arquivo para .env (dev) ou .env.prod (produção) e preencha os valores reais.
# NUNCA commite .env ou .env.prod no git.

# Node Environment (development | production)
NODE_ENV=development

# Port
PORT=3000

# Base URL (obrigatório em produção)
BASE_URL=https://supercartolamanager.com.br

# MongoDB Connection String
MONGO_URI=mongodb+srv://USER:PASS@cluster0.XXXXX.mongodb.net/cartola-manager?retryWrites=true&w=majority

# Session Secrets (gerar com: openssl rand -hex 32)
SESSION_SECRET=gerar_com_openssl_rand_hex_32
SESSION_SECRET_2=gerar_com_openssl_rand_hex_32
JWT_SECRET=gerar_com_openssl_rand_hex_32

# ===========================
# Google OAuth (Admin Auth)
# ===========================
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-seu_client_secret

# ===========================
# Admin Authorization
# ===========================
ADMIN_EMAILS=admin1@gmail.com,admin2@gmail.com
SUPER_ADMIN_EMAIL=admin1@gmail.com
ADMIN_KEY=admin1@gmail.com

# ===========================
# AI / External APIs
# ===========================
PERPLEXITY_API_KEY=pplx-sua_chave
GEMINI_API_KEY=AIzaSy-sua_chave
OPENAI_API_KEY=sk-proj-sua_chave
SOCCERDATA_API_KEY=sua_chave

# ===========================
# Big Cartola IA (RAG Chatbot) — opcionais, tem defaults
# ===========================
RAG_MODEL=gpt-4o-mini
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_MAX_TOKENS=500
RAG_TEMPERATURE=0.3
RAG_TOP_K=5

# ===========================
# Push Notifications (VAPID)
# ===========================
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=sua_chave_publica
VAPID_PRIVATE_KEY=sua_chave_privada
VAPID_SUBJECT=mailto:seu_email@gmail.com

# ===========================
# GitHub (deploy/webhooks/scripts)
# ===========================
GITHUB_TOKEN=ghp_seu_token_aqui
GITHUB_WEBHOOK_SECRET=gerar_com_openssl_rand_hex_32
GITHUB_OWNER=seu_usuario
GITHUB_REPO=SuperCartolaManagerv5-production
